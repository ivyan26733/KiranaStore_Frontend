# ── Server-side only (used in next.config.mjs rewrites, never sent to browser)
BACKEND_URL=http://localhost:5000        # dev
# BACKEND_URL=https://api.yourdomain.com  # production

# ── Client-side (safe to expose — no secrets here)
NEXT_PUBLIC_DEV_MODE=true               # set false in production
NEXT_PUBLIC_DEV_UID=dev-user-1          # ignored when DEV_MODE=false
